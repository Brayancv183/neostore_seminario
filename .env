# ─────────────────────────────────────────────────────────────────────────────
#  NeonStore — Variables de entorno
#  Copia este archivo a .env y completa los valores reales.
#  ¡NUNCA subas .env al control de versiones!
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Base de datos MySQL ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=neonstore_db

# ── Pool de conexiones (opcional — valores por defecto incluidos en db.js) ────
DB_POOL_CONNECTION_LIMIT=10
DB_POOL_QUEUE_LIMIT=0

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL del frontend en desarrollo
CORS_ORIGIN=http://localhost:5173
